# Confluence to Nextcloud Collectives Migration - Environment Variables
# Copy this file to .env and fill in your credentials

# Confluence Cloud settings
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
CONFLUENCE_USERNAME=your.email@example.com
CONFLUENCE_API_TOKEN=your-api-token-here

# Nextcloud settings
NEXTCLOUD_SERVER=https://cloud.example.com
NEXTCLOUD_USERNAME=your-username
NEXTCLOUD_PASSWORD=your-password-or-app-password
NEXTCLOUD_COLLECTIVE=YourCollectiveName
